# 🔒 .gitignore for Embedded C (Keil / ARM / LPC Projects)

# Build files

*.o
*.d
*.axf
*.elf
*.hex
*.bin
*.map

# Keil uVision files

*.uvoptx
*.uvopt
*.uvprojx
*.uvproj
*.uvguix.*
*.uvgui.*

# Debug / Output folders

/Debug/
/debug/
/Release/
/release/
/Objects/
/Listings/
/Output/

# Temporary files

*.bak
*.tmp
*.log

# OS generated files

.DS_Store
Thumbs.db

# Editor files

.vscode/
.idea/

# Backup files

*~
*.swp

# CMSIS / Library compiled files

*.lib
*.a

# Flash / Programming tool outputs

*.lst

# Misc

*.dep
